<%
/*
  Partial riutilizzabile: mostra una foto se disponibile, altrimenti il gradiente.

  Variabili richieste dal chiamante:
    item      — oggetto con .img, .imgMobile (opzionale), .imgGrad
    altText   — testo alt per l'immagine
    cssClass  — classe CSS da applicare al tag img/div (es. "card-img-bg")

  Logica:
    - Se item.img esiste → <picture> con srcset @card per contesti piccoli
    - Se item.imgMobile ma non item.img → solo mobile img, gradiente su desktop
    - Se nessuna img → gradiente

  Srcset automatico:
    Se item.img è "foo.webp", viene generato automaticamente
    un srcset con "foo@card.webp" per viewport ≤ 820px.
    Se il file @card non esiste semplicemente il browser usa il src principale.
*/

// Ricava il path @card dall'img principale (solo se è un file, non un gradiente)
const _cardImg = item.img
  ? item.img.replace(/(\.\w+)$/, '@card$1')
  : null;
%>
<% if (item.img || item.imgMobile) { %>
  <picture>
    <%/* versione card (piccola) per viewport stretti o contesti thumbnail */%>
    <% if (_cardImg) { %>
    <source media="(max-width: 820px)" srcset="<%= _cardImg %>">
    <% } %>
    <%/* versione mobile verticale (es. carosello) */%>
    <% if (item.imgMobile) { %>
    <source media="(max-width: 680px)" srcset="<%= item.imgMobile %>">
    <% } %>
    <% if (item.img) { %>
    <img
      src="<%= item.img %>"
      alt="<%= altText %>"
      class="<%= cssClass %>"
      style="object-fit:cover;width:100%;height:100%"
      loading="lazy"
    />
    <% } else { %>
    <%/* solo imgMobile: su desktop gradiente come fallback */%>
    <img
      src="<%= item.imgMobile %>"
      alt="<%= altText %>"
      class="<%= cssClass %>"
      style="object-fit:cover;width:100%;height:100%"
      loading="lazy"
    />
    <% } %>
  </picture>
<% } else { %>
  <div class="<%= cssClass %>" style="background:<%= item.imgGrad %>"></div>
<% } %>
