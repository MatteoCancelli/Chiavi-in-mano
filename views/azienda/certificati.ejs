<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="page-header">
  <span class="tag">Azienda · Certificazioni</span>
  <h1>Le nostre<br><em>Certificazioni</em></h1>
  <p>Documenti e attestati che certificano la qualità, la sicurezza e la professionalità del nostro lavoro.</p>
</div>

<div class="cert-grid">
  <% certificates.forEach(function(cert) { %>
  <div class="cert-card reveal">
    <!-- Anteprima -->
    <div class="cert-preview">
      <%- include('../partials/img-or-grad', { item: cert, altText: cert.name, cssClass: 'cert-preview-bg' }) %>
      <span class="cert-year"><%= cert.year %></span>
    </div>

    <!-- Info -->
    <div class="cert-body">
      <div class="cert-name"><%= cert.name %></div>
      <p class="cert-desc"><%= cert.description %></p>
      <% if (cert.file) { %>
      <a href="<%= cert.file %>" download class="cert-download">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M8 3v8M4 7l4 4 4-4M3 13h10"/>
        </svg>
        Scarica PDF
      </a>
      <% } else { %>
      <span class="cert-soon">In caricamento</span>
      <% } %>
    </div>
  </div>
  <% }) %>
</div>

<%- include('../partials/footer') %>
