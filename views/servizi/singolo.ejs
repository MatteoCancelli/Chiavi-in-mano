<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="page-header">
  <span class="tag">Step <%= step.num %> · <%= step.category %></span>
  <h1><%= step.title %></h1>
  <p><%= step.shortDesc %></p>
</div>

<div class="service-detail-wrap">

  <!-- Immagine hero -->
  <div class="service-hero-img">
    <%- include('../partials/img-or-grad', { item: step, altText: step.title, cssClass: 'service-hero-img-bg' }) %>
  </div>

  <!-- Meta -->
  <div class="service-meta">
    <div class="service-meta-item">
      Categoria
      <strong><%= step.category %></strong>
    </div>
    <div class="service-meta-item">
      Durata indicativa
      <strong><%= step.duration %></strong>
    </div>
    <% if (step.startHere) { %>
    <div class="service-meta-item">
      Accesso diretto
      <strong>Puoi iniziare da qui</strong>
    </div>
    <% } %>
  </div>

  <!-- Tags -->
  <div class="service-tags">
    <% step.tags.forEach(function(t) { %>
    <span class="service-tag"><%= t %></span>
    <% }) %>
  </div>

  <!-- Descrizione estesa -->
  <div class="service-body"><%= step.fullDesc %></div>

</div>

<!-- Progetti correlati -->
<% if (relatedProjects.length > 0) { %>
<div class="related-projects-section">
  <h3 class="related-title">Progetti che includono questo servizio</h3>
  <div class="projects-grid" style="padding:0;margin:0">
    <% relatedProjects.forEach(function(p) { %>
    <a href="/progetti?categoria=<%= encodeURIComponent(p.category) %>" class="project-card reveal">
      <div class="project-card-img">
        <%- include('../partials/img-or-grad', { item: p, altText: p.title, cssClass: 'project-card-img-bg' }) %>
        <div class="project-card-overlay">
          <div class="project-card-cat"><%= p.category %></div>
          <div class="project-card-title"><%= p.title %></div>
        </div>
      </div>
      <div class="project-card-body">
        <div class="project-card-loc">📍 <%= p.location %> · <%= p.year %></div>
        <p class="project-card-desc"><%= p.shortDesc %></p>
      </div>
    </a>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Navigazione tra servizi -->
<%
  const currentIdx = steps.findIndex(s => s.slug === step.slug);
  const prevStep   = steps[currentIdx - 1] || null;
  const nextStep   = steps[currentIdx + 1] || null;
%>
<div class="service-nav">
  <% if (prevStep) { %>
  <a href="/servizi/<%= prevStep.slug %>" class="service-nav-link prev">
    <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 8H3M7 4l-4 4 4 4"/></svg>
    <div>
      <div class="service-nav-label">Precedente</div>
      <div class="service-nav-name"><%= prevStep.title %></div>
    </div>
  </a>
  <% } else { %><div></div><% } %>

  <% if (nextStep) { %>
  <a href="/servizi/<%= nextStep.slug %>" class="service-nav-link next">
    <div>
      <div class="service-nav-label">Successivo</div>
      <div class="service-nav-name"><%= nextStep.title %></div>
    </div>
    <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
  </a>
  <% } else { %><div></div><% } %>
</div>

<section class="bottom-cta">
  <h2>Hai bisogno di<br><em><%= step.title.toLowerCase() %>?</em></h2>
  <p>Contattaci per un preventivo gratuito. Risposta entro 24 ore.</p>
  <a href="/contatti" class="btn-primary">
    Richiedi un preventivo
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
  </a>
</section>

<%- include('../partials/footer') %>
